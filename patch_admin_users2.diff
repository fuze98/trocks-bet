      {/* Users Section */}
      <section>
        <h2 className="text-3xl font-bold text-white mb-6">Customer Management</h2>
        <div className="bg-zinc-900 border border-zinc-800 rounded-xl overflow-hidden overflow-x-auto shadow-xl">
          <table className="w-full text-left whitespace-nowrap">
            <thead className="bg-zinc-950 border-b border-zinc-800">
              <tr>
                <th className="px-6 py-4 text-xs font-bold text-zinc-500 uppercase tracking-wider">Username</th>
                <th className="px-6 py-4 text-xs font-bold text-zinc-500 uppercase tracking-wider text-right">Balance</th>
                <th className="px-6 py-4 text-xs font-bold text-zinc-500 uppercase tracking-wider text-right">In Market (Pending)</th>
                <th className="px-6 py-4 text-xs font-bold text-zinc-500 uppercase tracking-wider text-right">Total P/L</th>
                <th className="px-6 py-4 text-xs font-bold text-zinc-500 uppercase tracking-wider text-right">Payback %</th>
                <th className="px-6 py-4 text-xs font-bold text-zinc-500 uppercase tracking-wider">Limit Multiplier</th>
                <th className="px-6 py-4 text-xs font-bold text-zinc-500 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody className="divide-y divide-zinc-800">
              {users.map(user => {
                const moneyInMarket = user.bets.filter(b => b.status === "Pending").reduce((acc, b) => acc + b.amount, 0);

                // Calculate P/L
                // Profit = Total Won - Total Wagered (on settled bets)
                const settledBets = user.bets.filter(b => b.status !== "Pending");
                const totalWageredSettled = settledBets.reduce((acc, b) => acc + b.amount, 0);
                const totalWon = settledBets.filter(b => b.status === "Won").reduce((acc, b) => acc + b.potentialWin, 0);
                // Push bets return the wager, so they don't affect P/L
                const totalProfit = totalWon - totalWageredSettled;

                // Payback % = (Total Won / Total Wagered) * 100
                const paybackPercent = totalWageredSettled > 0 ? (totalWon / totalWageredSettled) * 100 : 0;

                return (
                  <tr key={user.id} className="hover:bg-zinc-800/50 transition-colors">
                    <td className="px-6 py-4 text-sm font-bold text-white">{user.username}</td>
                    <td className="px-6 py-4 text-sm">
                      <form action={updateUserBalance.bind(null, user.id)} className="flex items-center justify-end gap-2">
                        <input
                          type="number"
                          name="amount"
                          defaultValue={user.balance}
                          step="0.01"
                          className="w-24 rounded bg-zinc-950 border border-zinc-700 py-1 px-2 text-green-400 font-mono text-right focus:ring-1 focus:ring-green-500"
                        />
                        <button type="submit" className="bg-zinc-700 hover:bg-zinc-600 text-white px-2 py-1 rounded text-xs font-medium">
                          Update
                        </button>
                      </form>
                    </td>
                    <td className="px-6 py-4 text-sm font-mono text-yellow-500 text-right">${moneyInMarket.toFixed(2)}</td>
                    <td className={`px-6 py-4 text-sm font-mono font-bold text-right ${totalProfit >= 0 ? 'text-green-500' : 'text-red-500'}`}>
                      {totalProfit >= 0 ? '+' : ''}${totalProfit.toFixed(2)}
                    </td>
                    <td className="px-6 py-4 text-sm font-mono text-zinc-300 text-right">{paybackPercent.toFixed(1)}%</td>
                    <td className="px-6 py-4 text-sm">
                      <form action={async (formData) => {
                        "use server";
                        const { updateUserLimit } = await import('../actions');
                        await updateUserLimit(user.id, formData.get("limitMultiplier") as string);
                      }} className="flex items-center gap-2">
                        <input
                          type="number"
                          step="0.05"
                          min="0"
                          name="limitMultiplier"
                          defaultValue={user.limitMultiplier}
                          className="w-20 rounded border border-zinc-700 bg-zinc-950 py-1 px-2 text-sm text-white focus:ring-1 focus:ring-green-500"
                        />
                        <button type="submit" className="text-xs bg-zinc-700 hover:bg-zinc-600 px-2 py-1 rounded text-white font-medium">Save</button>
                      </form>
                    </td>
                    <td className="px-6 py-4 text-sm">
                      <ResetPasswordButton userId={user.id} />
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </section>
